<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AW139 — Sparengine Audit Panels</title>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    margin: 0; padding: 1.5rem; background: #fafafa; color: #212121;
  }
  header {
    background: #fff; padding: 1rem 1.5rem; margin: -1.5rem -1.5rem 1.5rem;
    border-bottom: 1px solid #e0e0e0;
  }
  header h1 { margin: 0; font-size: 1.4rem; }
  header .meta { color: #666; font-size: 0.9rem; margin-top: 0.25rem; }
  .banner {
    padding: 0.75rem 1rem; margin-bottom: 1.5rem; border-radius: 4px;
    border-left: 4px solid; font-size: 0.95rem;
  }
  .banner.in_service       { background: #e8f5e9; border-color: #2e7d32; }
  .banner.redelivery_active { background: #fff3e0; border-color: #ef6c00; }
  .banner.unknown           { background: #f5f5f5; border-color: #9e9e9e; }
  .grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .panel {
    background: #fff; border: 1px solid #e0e0e0; border-radius: 4px;
    padding: 1rem 1.25rem;
  }
  .panel h2 { margin: 0 0 0.75rem; font-size: 1.05rem; color: #333;
              border-bottom: 1px solid #eee; padding-bottom: 0.5rem; }
  .panel ul { margin: 0; padding-left: 1.25rem; }
  .panel li { margin-bottom: 0.4rem; font-size: 0.9rem; }
  .badge { display: inline-block; padding: 0.1rem 0.4rem; border-radius: 3px;
           font-size: 0.75rem; margin-left: 0.4rem; }
  .badge.present { background: #c8e6c9; color: #1b5e20; }
  .badge.missing { background: #ffcdd2; color: #b71c1c; }
  .badge.level_1 { background: #ffcdd2; color: #b71c1c; }
  .badge.level_2 { background: #ffe0b2; color: #e65100; }
  .badge.level_3 { background: #fff9c4; color: #f57f17; }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
           gap: 0.75rem; margin-bottom: 1rem; }
  .stat { background: #fff; padding: 0.75rem; border-radius: 4px;
          border: 1px solid #e0e0e0; text-align: center; }
  .stat .v { font-size: 1.5rem; font-weight: 600; color: #1976d2; }
  .stat .k { font-size: 0.75rem; color: #757575; text-transform: uppercase;
             letter-spacing: 0.05em; }
  footer { margin-top: 1.5rem; color: #757575; font-size: 0.8rem; }
  pre { background: #f5f5f5; padding: 0.5rem; border-radius: 3px;
        overflow-x: auto; font-size: 0.8rem; }
</style>
</head>
<body>
<header>
  <h1 id="asset-title">AW139</h1>
  <div class="meta" id="asset-meta">Loading…</div>
</header>

<div id="banner" class="banner unknown">Loading lease-return state…</div>

<div class="stats" id="stats"></div>

<div class="grid">
  <div class="panel" id="panel-critical">
    <h2>Critical Items</h2>
    <p class="empty">Loading…</p>
  </div>
  <div class="panel" id="panel-checklist">
    <h2>Mandatory Checklist</h2>
    <p class="empty">Loading…</p>
  </div>
  <div class="panel" id="panel-findings">
    <h2>Findings (top 25)</h2>
    <p class="empty">Loading…</p>
  </div>
  <div class="panel" id="panel-quality">
    <h2>Audit Quality</h2>
    <p class="empty">Loading…</p>
  </div>
</div>

<footer>
  Generated by Sparengine Phase 10 → consumed from <code>graph_export.json</code>.
  Full graph viz available in Neo4j Browser at <code>http://localhost:7474</code>.
  Replay the per-asset graph via <code>cypher-shell -f restore.cypher</code>.
</footer>

<script>
fetch("graph_export.json")
  .then(r => r.json())
  .then(g => {
    // Asset header
    const a = g.asset || {};
    const title = a.name || a.value || "(unknown asset)";
    document.getElementById("asset-title").textContent = title;
    const meta = [
      a.subtype && `subtype: ${a.subtype}`,
      a.msn && `MSN: ${a.msn}`,
      a.registration && `reg: ${a.registration}`,
      a.type_certificate && `TC: ${a.type_certificate}`,
    ].filter(Boolean).join(" · ");
    document.getElementById("asset-meta").textContent = meta || "—";

    // Lease-return banner
    const lr = g.lease_return_state || {};
    const banner = document.getElementById("banner");
    banner.className = "banner " + (lr.state || "unknown");
    banner.textContent =
      `Lease-return state: ${lr.state || "unknown"}` +
      (lr.signal_count ? ` (${lr.signal_count} redelivery/delivery doc signals)` : "");

    // Stats row
    const stats = g.stats || {};
    const wanted = ["total_components", "total_events", "total_findings",
                    "total_documents", "total_pages", "total_stamps",
                    "total_form1s", "total_priority_items"];
    const statsEl = document.getElementById("stats");
    for (const k of wanted) {
      if (stats[k] === undefined) continue;
      const div = document.createElement("div");
      div.className = "stat";
      div.innerHTML = `<div class="v">${stats[k]}</div>` +
                      `<div class="k">${k.replace(/^total_/, "")}</div>`;
      statsEl.appendChild(div);
    }

    // Critical items
    const items = g.priority_items || [];
    const pCrit = document.getElementById("panel-critical");
    pCrit.querySelector(".empty")?.remove();
    if (items.length === 0) {
      pCrit.innerHTML += "<p>None.</p>";
    } else {
      const ul = document.createElement("ul");
      items.slice(0, 25).forEach(it => {
        const li = document.createElement("li");
        const urg = it.urgency || "informational";
        li.innerHTML =
          `<strong>${it.title || it.value}</strong> ` +
          `<span class="badge missing">${urg}</span><br>` +
          `<small>${it.description || ""}</small>`;
        ul.appendChild(li);
      });
      pCrit.appendChild(ul);
      if (items.length > 25) {
        pCrit.innerHTML += `<p><small>… and ${items.length - 25} more.</small></p>`;
      }
    }

    // Mandatory checklist
    const cl = g.mandatory_checklist || {};
    const pCl = document.getElementById("panel-checklist");
    pCl.querySelector(".empty")?.remove();
    if (Object.keys(cl).length === 0) {
      pCl.innerHTML += "<p>Checklist not populated.</p>";
    } else {
      const ul = document.createElement("ul");
      for (const [k, v] of Object.entries(cl)) {
        const li = document.createElement("li");
        li.innerHTML = `${k.replace(/_/g, " ")} <span class="badge ${v}">${v}</span>`;
        ul.appendChild(li);
      }
      pCl.appendChild(ul);
    }

    // Findings (flatten from {component_id: [...]})
    const findings = [];
    for (const [comp, list] of Object.entries(g.findings || {})) {
      for (const f of list) findings.push({ ...f, component_uid: comp });
    }
    const pF = document.getElementById("panel-findings");
    pF.querySelector(".empty")?.remove();
    if (findings.length === 0) {
      pF.innerHTML += "<p>No findings.</p>";
    } else {
      // Sort by severity (level_1 first)
      const sevOrder = { level_1: 0, level_2: 1, level_3: 2 };
      findings.sort((a, b) =>
        (sevOrder[a.severity] ?? 9) - (sevOrder[b.severity] ?? 9));
      const ul = document.createElement("ul");
      findings.slice(0, 25).forEach(f => {
        const li = document.createElement("li");
        const sev = f.severity || "level_3";
        li.innerHTML =
          `<span class="badge ${sev}">${sev}</span> ` +
          `<strong>${f.category || "?"}</strong>: ${f.title || ""}<br>` +
          `<small>${(f.description || "").slice(0, 200)}</small>`;
        ul.appendChild(li);
      });
      pF.appendChild(ul);
      if (findings.length > 25) {
        pF.innerHTML += `<p><small>… and ${findings.length - 25} more.</small></p>`;
      }
    }

    // Audit quality (severity totals + checklist coverage)
    const pQ = document.getElementById("panel-quality");
    pQ.querySelector(".empty")?.remove();
    const sev = stats.findings_by_severity || {};
    const present = Object.values(cl).filter(v => v === "present").length;
    const total = Object.keys(cl).length;
    const ul = document.createElement("ul");
    ul.innerHTML = `
      <li>Findings: <strong>${stats.total_findings || 0}</strong> total</li>
      <li>&nbsp;&nbsp;Level 1 (critical): <span class="badge level_1">${sev.level_1 || 0}</span></li>
      <li>&nbsp;&nbsp;Level 2 (significant): <span class="badge level_2">${sev.level_2 || 0}</span></li>
      <li>&nbsp;&nbsp;Level 3 (informational): <span class="badge level_3">${sev.level_3 || 0}</span></li>
      <li>Mandatory checklist coverage: <strong>${present}/${total}</strong> items present</li>
      <li>Components: ${stats.total_components || 0}</li>
      <li>Events: ${stats.total_events || 0}</li>
    `;
    pQ.appendChild(ul);
  })
  .catch(err => {
    document.body.innerHTML +=
      `<pre>Failed to load graph_export.json: ${err.message}</pre>`;
  });
</script>
</body>
</html>
