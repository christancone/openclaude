        "unknown_or_undocumented": { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
        "source_document_identified": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
      },
      "serviceability_status": {
        "serviceable":             { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
        "unserviceable":           { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
        "core_scrap_or_ber":       { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
