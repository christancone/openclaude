      "tasks_signed_off_with_stamp_and_signature": { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
      "tasks_listed_not_signed_off":               { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
      "missing_signoff_reason_identified":         { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "tasks_marked_not_required_or_na":           { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
      "tasks_deferred":                            { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
      "deferred_tasks_reference_target_wo":        { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "tasks_with_ambiguous_compliance_status":    { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
      "ambiguity_described":                       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "mts_vs_physical": {
