        "tso_confirmed_or_calculated_for_all":    { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
        "csn_confirmed_or_calculated_for_all":    { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
