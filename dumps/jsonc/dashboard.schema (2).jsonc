    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 10 — GRAPH QUALITY INDICATORS
  // ---------------------------------------------------------------------------
  // Sparengine-internal data quality metrics. Some counts are EXPECTED to be 0
  // and only require justification when > 0 (singletons, orphans, stamps with
  // no binding target, rotation issues, poor scan quality).
  "graph_quality_indicators": {
    "total_source_files_ingested":              { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "total_chunks_processed":                   { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "physical_records_and_mts_exports_distinguished": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "mts_data_points_flagged_separately":       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "components_with_all_six_key_fields":       { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
    "missing_fields_identified_for_each_component_with_gaps": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "context_discrepancies_detected":           { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "each_discrepancy_described_and_flagged":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "singleton_nodes_with_no_connections":      { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // expected 0 — justify only when > 0
    "orphan_documents":                         { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // expected 0
    "cross_references_resolved":                { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
    "tsn_csn_baseline_confidence":              { "value": "<Verified | Config_fallback | Unknown>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "tsn_csn_baseline_discrepancy_source_identified": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "batch_numbers_for_non_serialised_parts":   { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "batch_numbers_linked_to_install_records":  { "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked", "documents": [], "citations": [] },
    "evidentiary_weight_assessed_for_all_documents": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "documents_classified_into_evidence_classes": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "secondary_or_administrative_evidence_findings_flagged": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "stamp_binding_and_spatial_context_verified": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "all_stamps_correctly_bound":               { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "stamps_with_ambiguous_binding_flagged":    { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "stamps_with_no_binding_target":            { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // expected 0
    "scan_quality_and_rotation_assessed_for_all_pages": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "pages_with_rotation_issues":               { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // expected 0
    "rotation_corrected_before_extraction":     { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
    "pages_with_poor_scan_quality":             { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // expected 0
    "poor_quality_pages_flagged_for_manual_review": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
  },

  // ---------------------------------------------------------------------------
  // SECTION 11 — OVERALL QUALITY SCORE
  // ---------------------------------------------------------------------------
  // Note from checklist: only PERCENT items feed the overall score. Yes/No and
  // counts are excluded. The 'overall' field is calculated as the average of
  // the six percent inputs and MUST carry method:"calculated" with a
  // computation string and inputs[] referencing each input's tracked claim.
  "overall_quality_score": {
    "documents_complete": {                                               // # docs found across S2,S3,S4 / total expected
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "component_data_complete": {                                          // # components with all key fields / total components
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "ad_compliance_complete": {                                           // # ADs with compliance record / total applicable ADs
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "sb_compliance_complete": {                                           // # SBs with compliance record / total applicable SBs
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "form_1_coverage": {                                                  // # serialised components with Form 1 confirmed and SN match / total serialised
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "task_compliance_complete": {                                         // # tasks signed off / total tasks
      "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "overall": {                                                          // simple average of the six above
      "value": 0, "unit": "%", "method": "calculated",
      "computation": "average(documents_complete.percent, component_data_complete.percent, ad_compliance_complete.percent, sb_compliance_complete.percent, form_1_coverage.percent, task_compliance_complete.percent)",
      "inputs": [
        // Each input is a tracked-claim shape pointing back to one of the six fields above.
        // Example shape:
        // {
        //   "label": "documents_complete",
        //   "value": { "numerator": 0, "denominator": 0, "percent": 0 }, "unit": "%", "method": "calculated",
        //   "documents": [], "citations": []
        // }
      ],
      "documents": [], "citations": []
    }
  },

  // ===========================================================================
  // TOP-LEVEL ARRAYS — referenced by ID from the sections above
  // ===========================================================================

  // ---------------------------------------------------------------------------
  // COMPONENTS
  // ---------------------------------------------------------------------------
  // ONE unified schema for every serialized item: engines, APU, NLG/MLG,
  // wheels, brakes, batteries, ELT, life rafts, PBEs, life vests, oxygen
  // cylinders, fire extinguishers, AND every individual LLP within an
  // assembly. Filter by component_category to render specialized tables:
  //   - Component table:  list ALL records.
  //   - LLP table:        filter component_category === "LLP".
  // LLP-specific fields are populated only when component_category === "LLP".
  "components": [
    {
      "id":                       "<component id, e.g. comp_wheel_3_MAY18-4688>",  // plain string, internal ref
      "description":              { "value": "<string>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "part_number":              { "value": "<string>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "alternate_part_numbers": [
        // Each entry is itself a tracked-claim string. Use this for OEM PN /
        // vendor PN / operator PN aliases. Lukas's wheel example:
        //   primary part_number = Honeywell PN "5012373"
        //   alternate           = Bombardier OEM PN "K600-85032-5"
      ],
      "serial_number":            { "value": "<string>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "position":                 { "value": "<string e.g. 'RH INBD (#3)' | 'LH MLG' | 'FWD LH'>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "component_category":       "LLP",        // enum: LLP | Hard_Time | On_Condition | Time_Limit | Calendar
      "part_status_at_installation": { "value": "<New | Repaired | Overhauled | Inspected | Used | Unknown>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "status":                   "CLOSED",      // enum: CLOSED | PARTIAL | INSTALLED_AT_MANUFACTURING | GAP_IN_DOSSIER
      "parent_assembly_id":       null,          // string ref into another components[].id — for LLPs and subcomponents (e.g. wheel inside MLG, LLP inside engine); null when standalone
      "first_install_date":       { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "first_install_ac_tsn":     { "value": "<HHH:MM>",     "unit": "h",  "method": "not_checked", "documents": [], "citations": [] },
      "first_install_ac_csn":     { "value": 0,              "unit": "cy", "method": "not_checked", "documents": [], "citations": [] },
      "last_repair_date":         { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_repair_ac_tsn":       { "value": "<HHH:MM>",     "unit": "h",  "method": "not_checked", "documents": [], "citations": [] },
      "last_repair_ac_csn":       { "value": 0,              "unit": "cy", "method": "not_checked", "documents": [], "citations": [] },
      "removal_date":             { "value": null,           "unit": null, "method": "not_checked", "documents": [], "citations": [] }, // null when currently installed
      "removal_tsn":              { "value": null,           "unit": "h",  "method": "not_checked", "documents": [], "citations": [] },
      "removal_csn":              { "value": null,           "unit": "cy", "method": "not_checked", "documents": [], "citations": [] },
      "calendar_months_since_new": { "value": 0,             "unit": "months", "method": "not_checked", "documents": [], "citations": [] },
      "hours_since_repair":       { "value": "<HHH:MM>",     "unit": "h",  "method": "not_checked", "documents": [], "citations": [] }, // TSO-h
      "cycles_since_repair":      { "value": 0,              "unit": "cy", "method": "not_checked", "documents": [], "citations": [] }, // TSO-cy
      "modification_status":      { "value": "<NIL | description of mods>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "special_inspections": [
        // Array of tracked-claim strings — each describes one special inspection
        // performed (e.g. "BEAD SEAT EDDY CURRENT NDT (Form 1 Block 12)").
      ],
      "subcomponent_change_history": [
        // Array of subcomponent change events. Use for tire changes on wheels,
        // blade changes on propellers, module swaps on engines, etc.
        // Each entry:
        // {
        //   "event_date":      <tracked-claim date>,
        //   "work_order":      <tracked-claim string>,
        //   "removed_pn":      <tracked-claim string>,
        //   "removed_sn":      <tracked-claim string>,
        //   "installed_pn":    <tracked-claim string>,
        //   "installed_sn":    <tracked-claim string>,
        //   "release_certificate": <tracked-claim string e.g. "FAA 8130-3">,
        //   "notes":           <tracked-claim string>
        // }
      ],
      "form_1_reference":         { "value": "<string e.g. 'EASA Form 1 L-337470, AMAC WO R0506421, signer Kaiser Frank (FKA), CH.145.0363'>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "snapshot_date":            { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "finding_ids":              [ /* array of finding IDs that reference this component */ ],

      // -------------------------------------------------------------------
      // LLP-only fields — populate ONLY when component_category === "LLP".
      // For non-LLP components, omit these keys (or set to null + method:"not_applicable").
      // -------------------------------------------------------------------
      "life_limit": {
        "value":  0,                                                      // numeric limit
        "unit":   "cy",                                                   // "cy" | "h" | "months"
        "method": "not_checked",
        "documents": [], "citations": []
      },
      "tsn_at_event":             { "value": "<HHH:MM>", "unit": "h",  "method": "not_checked", "documents": [], "citations": [] }, // TSN at the most recent shop visit / overhaul
      "csn_at_event":             { "value": 0,          "unit": "cy", "method": "not_checked", "documents": [], "citations": [] }, // CSN at the most recent shop visit / overhaul. CRITICAL — without this, remaining life cannot be calculated.
      "remaining_life_until_overhaul": { "value": null, "unit": "cy", "method": "not_checked", "documents": [], "citations": [] }, // value type matches life_limit.unit; null when unresolvable
      "remaining_life_until_discard":  { "value": null, "unit": "cy", "method": "not_checked", "documents": [], "citations": [] },
      "first_limited_indicator":  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }  // true when this LLP has the FEWEST cycles remaining among LLPs on the same engine — drives executive summary surfacing
    }
    // ... additional component records follow this same shape ...
  ],

  // ---------------------------------------------------------------------------
  // FINDINGS
  // ---------------------------------------------------------------------------
  // Top-level flat array of all audit findings. Severity follows Lukas's
  // L1/L2/L3 scheme exactly:
  //   level_1 = airworthiness block, must resolve before transaction closes
  //   level_2 = data correction, work was done but recorded wrong
  //   level_3 = improvement, will recur in future audits if ignored
  // Categories are extensible but should use the established enum where applicable.
  "findings": [
    {
      "id":          "<finding id, e.g. F-0001>",                         // plain string
      "severity":    "level_1",                                           // enum: level_1 | level_2 | level_3
      "category":    "FORM1_MISSING",                                     // enum: FORM1_MISSING | GAP_IN_DOSSIER | AD_COMPLIANCE_UNVERIFIED | LLP_LIMIT_CRITICAL | TASK_NOT_CONFIRMED | SN_AMBIGUOUS | SB_WITHOUT_CRS | CONTINUITY_BREAK | SHOP_VISIT_MISSING | TIMES_INCOMPLETE | MTS_CONFLICT | DATE_ANOMALY | BATCH_FORM1_PENDING | <extensible>
      "title":       "<short headline, e.g. 'RH Engine HPT disc has 605 cycles remaining'>",
      "description": "<long-form description of the finding>",
      "location": {
        "section":                   "<section key, e.g. 'engines_and_apu'>",
        "path":                      "<dotted path into the section, e.g. 'engines_and_apu.rh_engine.llps'>",
        "affected_component_ids":    [ /* refs into components[].id */ ]
      },
      "justification":      "<why this is a finding — must reference the documents and citations below>",
      "recommended_action": "<what the buyer/operator should do to close the gap>",
      "documents":          [],                                           // same shape as on tracked claims
      "citations":          []                                            // same shape as on tracked claims — bbox highlights the proof
    }
    // ... additional findings follow this same shape ...
  ],

  // ---------------------------------------------------------------------------
  // DOSSIER DOCUMENTS
  // ---------------------------------------------------------------------------
  // Master inventory of every document in the corpus. Citations elsewhere
  // reference these by id. Document-level metadata lives ONLY here (file
  // name, evidence class, page count, scan-quality flags, ingestion date).
  // The found/expired/valid assessments for known document types (CofA,
  // ARC, AFM, etc.) live INLINE in sections 2/3/5 — not on the document.
  "dossier_documents": [
    {
      "id":             "<document id, e.g. doc_018>",                    // plain string, internal ref
      "file_name":      "<original file name, e.g. CL65HBJTZ015MX.pdf>",
      "document_type":  "<enum value>",                                   // Form_1 | CRS | WorkOrder | JobCard | Logbook | CofA | ARC | AFM | AMM | IPC | TLMC | MTS_Export | ServiceRecord | NoiseCertificate | RadioLicense | MEL | OpsSpec | WeightAndBalance | DentBuckleChart | RepairOrder | STC | AFMS | ICA | NDTReport | BorescopeReport | ConditionReport | HardTimeStatus | other
      "evidence_class": "<enum>",                                         // primary | secondary | administrative | reference
      "page_count":     0,                                                // total pages in the PDF
      "scan_quality_flags": [
        // Free-form strings describing per-page quality issues, e.g.
        // "rotation_issue:p33", "poor_scan:p104", "low_contrast:p77-79".
        // Empty array when no issues.
      ],
      "ingestion_date": "<YYYY-MM-DD>",                                   // when Sparengine ingested this document
      "asset_id_link":  "<asset_id this document belongs to, e.g. CL650-6134>"
    }
    // ... additional document records follow this same shape ...
  ]
}
