// =============================================================================
// SPARENGINE DASHBOARD JSON — SCHEMA
// =============================================================================
//
// Purpose: defines the shape of the per-aircraft audit JSON consumed by the
// customer dashboard. Every key Lukas's Graph Quality Assessment Checklist
// asks for is represented here; the dashboard reads this shape and renders
// per-aircraft views.
//
// File format: JSONC (JSON with Comments). Strip `//` and `/* */` comments
// before parsing as plain JSON. The placeholder values inside this file
// (e.g. "<HHH:MM string>") are not valid runtime data — they describe what
// belongs in each slot. See CL650-6134-dashboard-example.jsonc for a real
// populated instance.
//
// =============================================================================
// SHARED SHAPE — TRACKED CLAIM WRAPPER
// =============================================================================
// Every quantitative or factual claim about the aircraft is wrapped in this
// shape. The wrapper carries the value AND its provenance, so the dashboard
// can always render "where did this come from?"
//
//   {
//     "value":  <scalar | string | true | false | null | { numerator, denominator, percent }>,
//     "unit":   "h" | "cy" | "months" | "%" | null,           // null for non-numeric/Yes-No/string
//     "method": "confirmed" | "calculated" | "inferred" | "unknown" |
//               "unresolvable" | "not_applicable" | "not_checked",
//
//     // Populated when method === "calculated":
//     "computation": "TSN = AC TSN at cut-off (559:25) - AC TSN at install (0:00) = 559:25",
//     "inputs":      [ /* nested tracked-claim shapes; each carries its own documents+citations */ ],
//
//     // Populated when value === false OR method ∈ {unresolvable, unknown}:
//     "justification":         "...why we couldn't confirm / why the answer is No...",
//     "recommended_documents": [ "Description of doc that would resolve the gap", ... ],
//
//     // Provenance — always present unless method === "not_checked":
//     "documents":  [ { "id": "doc_xxx" }, ... ],   // refs into top-level dossier_documents[]
//     "citations":  [
//       {
//         "document": 0,                  // index into local documents[] above
//         "page":     208,                // 1-based, document-local
//         "regions":  [
//           {
//             "bbox": { "x": 0.35, "y": 0.42, "width": 0.18, "height": 0.05 },  // normalized [0..1], top-left origin
//             "contribution": "Block 12 — TSN at installation",                  // human-readable description of WHAT this region proves
//             "excerpt":      "TSN: 0:00"                                        // optional: the literal text in the region
//           }
//         ]
//       }
//     ]
//   }
//
// Number / % fields use { numerator, denominator, percent } as the value:
//   "value": { "numerator": 47, "denominator": 53, "percent": 88.7 }
//
// =============================================================================
// CONVENTIONS
// =============================================================================
// - Hours:    HHH:MM strings ("410:41"), NOT decimals.
// - Cycles:   integers.
// - Dates:    ISO 8601 — "YYYY-MM-DD" for date-only, "YYYY-MM-DDTHH:MM:SSZ" for full timestamps.
// - Percent:  number 0–100, up to 2 decimals.
// - IDs:      plain strings, NOT wrapped (component_id, finding_id, document_id are
//             internal references, not aircraft facts).
// - Coverage: every checklist item is ALWAYS present in the JSON. Items not yet
//             assessed have method: "not_checked" and may omit documents/citations.
// =============================================================================
{
  // ---------------------------------------------------------------------------
  // METADATA ENVELOPE
  // ---------------------------------------------------------------------------
  "schema_version":       "<semver string, e.g. '1.0.0'>",                // schema version this document conforms to
  "generated_at":         "<ISO 8601 UTC timestamp>",                     // when this file was produced
  "audit_run_id":         "<unique string per audit run>",                // for tracing back to the Sparengine run that produced this
  "sparengine_version":   "<semver of the Sparengine release>",           // tool version
  "dossier_cut_off_date": "<YYYY-MM-DD>",                                 // the as-of date for utilization values (TSN/CSN snapshot)
  "audit_snapshot_date":  "<YYYY-MM-DD>",                                 // when this audit ran (≥ dossier_cut_off_date)
  "asset_id":             "<asset identifier, e.g. CL650-6134>",          // primary key for the aircraft
  "asset_type":           "aircraft",                                     // enum reserved for future expansion (engine_only, propeller, etc.)

  // ---------------------------------------------------------------------------
  // PRE-FLIGHT CHECK
  // ---------------------------------------------------------------------------
  // Lukas's first sanity gate: is the corpus complete enough to even attempt
  // an assessment? If No, the rest of the report is provisional.
  "pre_flight_check": {
    "corpus_complete_for_reliable_assessment": {                          // tracked-claim Yes/No
      "value": null, "unit": null, "method": "not_checked",
      "justification": "<populate when value === false>",
      "recommended_documents": [],
      "documents": [], "citations": []
    },
    "missing_corpus_description": {                                       // tracked-claim string — only relevant when corpus_complete is No
      "value": null, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 1 — AIRCRAFT IDENTIFICATION
  // ---------------------------------------------------------------------------
  "aircraft_identification": {
    "aircraft_registration": {                                            // string identity (e.g. "HB-JTZ"), wrapped for provenance
      "value": "<string>", "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "serial_number": {                                                    // MSN — manufacturer serial number (e.g. "6134")
      "value": "<string>", "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "model_and_variant": {                                                // e.g. "Bombardier CL-650 (CL-600-2B16)"
      "value": "<string>", "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "certification_date": {                                               // C of A issuance / type-cert applicability
      "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "total_airframe_hours": {                                             // current AC TSN at dossier cut-off
      "value": "<HHH:MM string>", "unit": "h", "method": "not_checked",
      "documents": [], "citations": []
    },
    "airframe_hours_match_logbook": {                                     // Yes/No — TSN at cut-off matches last airframe logbook entry
      "value": null, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "total_airframe_cycles": {                                            // current AC CSN at dossier cut-off
      "value": 0, "unit": "cy", "method": "not_checked",
      "documents": [], "citations": []
    },
    "airframe_cycles_match_logbook": {                                    // Yes/No
      "value": null, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "total_components_found": {                                           // count of records in components[]
      "value": 0, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "unique_part_numbers_found": {                                        // distinct PN count
      "value": 0, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "unique_serial_numbers_found": {                                      // distinct SN count
      "value": 0, "unit": null, "method": "not_checked",
      "documents": [], "citations": []
    },
    "components_with_pn_and_sn_confirmed": {                              // Number / % — uses ratio value
      "value": { "numerator": 0, "denominator": 0, "percent": 0 },
      "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "components_with_pn_only": {                                          // Number / %
      "value": { "numerator": 0, "denominator": 0, "percent": 0 },
      "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "components_with_sn_only": {                                          // Number / %
      "value": { "numerator": 0, "denominator": 0, "percent": 0 },
      "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    },
    "components_with_neither_pn_nor_sn": {                                // Number / %
      "value": { "numerator": 0, "denominator": 0, "percent": 0 },
      "unit": "%", "method": "not_checked",
      "documents": [], "citations": []
    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 2 — KEY DOCUMENTS FOUND
  // ---------------------------------------------------------------------------
  // Each known document type has its own block. document_id (when present)
  // refers into top-level dossier_documents[]. Assessment claims (found,
  // expiry_date, currently_valid) live INLINE here, not on the document record.
  "key_documents": {
    "certificate_of_airworthiness": {
      "document_id": null,                                                // string ref into dossier_documents[] | null when not found
      "found":             { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "expiry_date":       { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "currently_valid":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "airworthiness_review_certificate": {                                 // ARC
      "document_id": null,
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "expiry_date":     { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "currently_valid": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "certificate_of_registration": {
      "document_id": null,
      "found":                       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "registration_matches_aircraft": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "radio_license": {
      "document_id": null,
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "currently_valid": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "noise_certificate": {
      "document_id": null,
      "found": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "aircraft_flight_manual": {                                           // AFM
      "document_id": null,
      "found":                          { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "all_supplements_found":          { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "supplements_match_stcs_and_mods": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "weight_and_balance_report": {
      "document_id": null,
      "found":                  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "report_date":            { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "current_and_not_overdue": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "minimum_equipment_list": {                                           // MEL
      "document_id": null,
      "found": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "operations_specifications": {
      "document_id": null,
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "currently_valid": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "redelivery_or_delivery_acceptance": {                                // optional — Not Applicable for first-owner aircraft
      "document_id": null,
      "applicability": "<Applicable | NotApplicable>",                    // string flag — drives whether the next two fields render
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "matches_current_configuration":      { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "paint_and_interior_condition_documentation": {
      "document_id": null,
      "found":                                       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "covers_exterior_and_interior":                { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "dated_and_signed_by_authorised_person":       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "noted_defects_have_repair_or_acceptance":     { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 3 — LOGBOOKS
  // ---------------------------------------------------------------------------
  // Each logbook block follows the same pattern: found, sequential continuity,
  // last entry matches asset node. Engine logbooks reference engine_id; APU
  // logbook references apu_id; main/APU battery logbooks reference component IDs.
  "logbooks": {
    "airframe": {
      "document_id": null,
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "sequential_continuity_no_gaps":      { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_entry_tsn_csn_matches_aircraft": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "lh_engine": {
      "document_id": null,
      "engine_component_id": null,                                        // ref into components[] for the LH engine
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "sequential_continuity_no_gaps":      { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_entry_tsn_csn_matches_engine":  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "rh_engine": {
      "document_id": null,
      "engine_component_id": null,
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "sequential_continuity_no_gaps":      { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_entry_tsn_csn_matches_engine":  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "apu": {
      "document_id": null,
      "apu_component_id": null,
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "sequential_continuity_no_gaps":      { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_entry_tsh_cycles_matches_apu":  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "main_battery": {
      "document_id": null,
      "battery_component_id": null,
      "found":                       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_service_entry_confirmed": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "apu_battery": {
      "document_id": null,
      "battery_component_id": null,
      "found":                       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_service_entry_confirmed": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 4 — BATTERY AND EMERGENCY EQUIPMENT
  // ---------------------------------------------------------------------------
  // Calendar-based items. Each equipment instance references a component_id in
  // components[]. The detailed PN/SN/install/etc. lives on the component; this
  // section captures the inspection/replacement currency status.
  "battery_and_emergency_equipment": {
    "main_battery": {
      "component_id": null,
      "service_record_found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_service_date":              { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "next_due_date":                  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "within_approved_service_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "capacity_check_confirmed":       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "apu_battery": {
      "component_id": null,
      "service_record_found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_service_date":              { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "next_due_date":                  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "within_approved_service_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "capacity_check_confirmed":       { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "elt": {                                                              // Emergency Locator Transmitter
      "component_id": null,
      "found":                              { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "battery_last_replacement_date":      { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "battery_next_replacement_due_date":  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "battery_within_approved_interval":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "last_operational_test_date":         { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "next_operational_test_due_date":     { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "operational_test_current_not_overdue": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "life_rafts": {
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "total_count":     { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "instances": [                                                      // one entry per life raft, keyed by component_id
        {
          "component_id": null,
          "last_repack_date":           { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_repack_due_date":       { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "repack_within_approved_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "hydrostatic_test_date":      { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_hydrostatic_test_due":  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "hydrostatic_test_current":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
        }
      ]
    },
    "portable_breathing_equipment": {                                     // PBE
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "total_count":     { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "instances": [
        {
          "component_id": null,
          "expiry_date":               { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "time_remaining":            { "value": "<HHH:MM string or N months>", "unit": "months", "method": "not_checked", "documents": [], "citations": [] },
          "within_approved_service_life": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
        }
      ]
    },
    "portable_fire_extinguishers": {
      "found":           { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "instances": [
        {
          "component_id": null,
          "last_service_date":          { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_service_due_date":      { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "service_within_approved_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "hydrostatic_test_date":      { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_hydrostatic_test_due":  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "hydrostatic_test_current":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
        }
      ]
    },
    "life_vests": {
      "found":         { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "total_count":   { "value": 0, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "instances": [
        {
          "component_id": null,
          "last_inspection_date":       { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_inspection_due_date":   { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "inspection_within_approved_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
        }
      ]
    },
    "oxygen_cylinders": {
      "found":         { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "instances": [
        {
          "component_id": null,
          "last_hydrostatic_test_date": { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "next_hydrostatic_test_due":  { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
          "hydrostatic_test_current":   { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
        }
      ],
      "crew_oxygen_mask_regulators": {
        "overhaul_status_confirmed":    { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
        "last_overhaul_date":           { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
        "next_overhaul_due_date":       { "value": "<YYYY-MM-DD>", "unit": null, "method": "not_checked", "documents": [], "citations": [] },
        "overhaul_within_approved_interval": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
      }
    }
  },

  // ---------------------------------------------------------------------------
  // SECTION 5 — MANUALS
  // ---------------------------------------------------------------------------
  "manuals": {
    "aircraft_maintenance_manual": {                                      // AMM
      "document_id": null,
      "found":                  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "revision_status":        { "value": "<string e.g. 'Rev 23, Jan 2025'>", "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "illustrated_parts_catalog": {                                        // IPC
      "document_id": null,
      "found":                  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "revision_status":        { "value": "<string>", "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "wiring_diagram_manual": {                                            // WDM
      "document_id": null,
      "found": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "fault_isolation_manual": {                                           // FIM
      "document_id": null,
      "found": { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
    "component_maintenance_manuals": {                                    // CMM — for major components
      "found":                                  { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] },
      "cmms_match_installed_component_pns":     { "value": null, "unit": null, "method": "not_checked", "documents": [], "citations": [] }
    },
