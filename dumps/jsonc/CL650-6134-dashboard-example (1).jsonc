  // ---------------------------------------------------------------------------
  // FINDINGS
  // ---------------------------------------------------------------------------
  "findings": [

    // ─────────────────────────────────────────────────────────────────────
    // F-0001 — LEVEL 1 — AD register missing (mandatory PPI deliverable)
    // ─────────────────────────────────────────────────────────────────────
    {
      "id":          "F-0001",
      "severity":    "level_1",
      "category":    "AD_COMPLIANCE_UNVERIFIED",
      "title":       "Airworthiness Directive compliance register not found in dossier",
      "description": "No comprehensive AD compliance register or MTS export with AD section present. Per Lukas Weiss's audit doctrine, AD compliance is ALWAYS a mandatory PPI deliverable; absence at this level blocks airworthiness assessment regardless of how complete the rest of the records are.",
      "location": {
        "section":                "records_completeness",
        "path":                   "records_completeness.airworthiness_directives.ad_list_file_found",
        "affected_component_ids": []
      },
      "justification":      "Records search across all 12 ingested documents for 'AD compliance', 'airworthiness directive', and known EASA AD numbers for CL-600-2B16 / CF34-3B returned no matching content. Operator's MTS export not provided.",
      "recommended_action": "Request from operator: complete AD compliance register for HB-JTZ as of 2022-12-29 dossier date, OR a MTS export including the AD compliance section.",
      "documents":          [],
      "citations":          []
    },

    // ─────────────────────────────────────────────────────────────────────
    // F-0002 — LEVEL 2 — APU records gap
    // ─────────────────────────────────────────────────────────────────────
    {
      "id":          "F-0002",
      "severity":    "level_2",
      "category":    "GAP_IN_DOSSIER",
      "title":       "APU records (PN, SN, logbook, TSH) not in compiled dossier",
      "description": "APU identification and utilization records were not included in the dossier provided. This appears to be a dossier-completeness issue, not an airworthiness issue — the operator likely maintains these records in their MTS or in a separate APU binder that was not bundled.",
      "location": {
        "section":                "engines_and_apu",
        "path":                   "engines_and_apu.apu",
        "affected_component_ids": ["comp_apu"]
      },
      "justification":      "No APU logbook found; APU PN/SN not present in any ingested document. Lukas: 'not in this dossier' ≠ 'does not exist' — recommend GAP_IN_DOSSIER classification, not FORM1_MISSING.",
      "recommended_action": "Request from operator: APU logbook, current APU TSH/cycles status, and APU shop visit history.",
      "documents":          [],
      "citations":          []
    },

    // ─────────────────────────────────────────────────────────────────────
    // F-0003 — LEVEL 1 — first-limited LLP surfacing (executive summary lead)
    // ─────────────────────────────────────────────────────────────────────
    {
      "id":          "F-0003",
      "severity":    "level_1",
      "category":    "LLP_LIMIT_CRITICAL",
      "title":       "RH Engine HPT Stage 1 disc — 11,769 cy remaining (first-limited LLP on RH engine)",
      "description": "Among RH engine LLPs surfaced in this run, the HPT Stage 1 disc has the most remaining cycles. Note: in the example data only one LLP is populated; in production this finding would surface the LLP with the FEWEST remaining cycles per Lukas's executive-summary priority.",
      "location": {
        "section":                "life_limited_parts",
        "path":                   "life_limited_parts.rh_engine_llps",
        "affected_component_ids": ["comp_rh_engine_hpt_disc"]
      },
      "justification":      "Remaining life (cycles) = Life limit (12000 cy) − CSN at event (0 cy) − cycles since event (231 cy) = 11769 cy. Source: Engine logbook RH p32, life limit table. Threshold for L1 surfacing is < 1500 cy remaining; THIS specific disc is well above threshold but the finding pattern is shown for shape demonstration. In a real CL650-6134 audit, the LLP nearest the threshold would be surfaced.",
      "recommended_action": "Continue monitoring; no immediate action. Schedule next LLP review at 9000 CSN.",
      "documents":          [{ "id": "doc_008" }],
      "citations": [
        { "document": 0, "page": 32,
          "regions": [
            { "bbox": { "x": 0.10, "y": 0.30, "width": 0.85, "height": 0.04 },
              "contribution": "LLP table row for HPT Stage 1 disc",
              "excerpt": "HPT Disc S1 — PN 6076T74G02 — SN WJYW0481 — Limit 12000 cy" }
          ]
        }
      ]
    },

    // ─────────────────────────────────────────────────────────────────────
    // F-0004 — LEVEL 2 — battery service record missing
    // ─────────────────────────────────────────────────────────────────────
    {
      "id":          "F-0004",
      "severity":    "level_2",
      "category":    "TIMES_INCOMPLETE",
      "title":       "Main battery service record absent — calendar interval check unresolvable",
      "description": "No capacity-check or service record present in the dossier for the main battery (PN BAT-9-105B, SN B19-44021). Cannot determine last service date, next due date, or calendar interval compliance.",
      "location": {
        "section":                "battery_and_emergency_equipment",
        "path":                   "battery_and_emergency_equipment.main_battery",
        "affected_component_ids": ["comp_main_battery"]
      },
      "justification":      "No record of battery capacity check, replacement, or service event found in any of the 12 ingested documents. Battery age (~45 months since aircraft delivery) exceeds typical 12-month capacity check interval, suggesting service must have occurred — but the record is not in the dossier.",
      "recommended_action": "Request from operator: full main battery service log since aircraft delivery (2019-04-03) including capacity check entries.",
      "documents":          [],
      "citations":          []
    },

    // ─────────────────────────────────────────────────────────────────────
    // F-0005 — LEVEL 2 — RH MLG prior aircraft history not traced
    // ─────────────────────────────────────────────────────────────────────
    {
      "id":          "F-0005",
      "severity":    "level_2",
      "category":    "CONTINUITY_BREAK",
      "title":       "RH MLG SN 08MDT0455 has prior service on CL604/5783 and CL605/5784 — back-to-birth trace incomplete",
